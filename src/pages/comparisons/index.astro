---
import BaseLayout from '../../layouts/BaseLayout.astro';
const now = new Date();
const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const buildDate = `${months[now.getMonth()]} ${now.getFullYear()}`;

const articles = [
  {
    href: '/comparisons/samsung-galaxy-ring-vs-oura-ring',
    title: 'Samsung Galaxy Ring vs Oura Ring 4: Which to Buy',
    desc: 'The two best smart rings head to head. Which one wins depends on your phone and priorities.',
    time: '10 min read',
  },
  {
    href: '/comparisons/oura-ring-alternatives-no-subscription',
    title: 'Oura Ring Alternatives With No Monthly Subscription',
    desc: 'The best alternatives to the Oura Ring with no subscription fee. Tested and compared.',
    time: '8 min read',
  },
];
---
<BaseLayout title="Smart Ring Comparisons (2026) — Head-to-Head Tests | RingAdvice" description="Independent smart ring comparisons based on real testing. Samsung Galaxy Ring vs Oura Ring, alternatives without subscription and more." lang="en" enPath="/comparisons" esPath="/es/comparativas">
<section style="padding:clamp(40px,6vw,80px) 0;">
  <div class="container">
    <nav style="margin-bottom:24px;font-size:12px;font-family:monospace;color:rgba(255,255,255,0.3);">
      <a href="/" style="color:rgba(255,255,255,0.35);">ringadvice</a> / <span style="color:#00FFB2;">comparisons</span>
    </nav>
    <span class="badge badge--orange">COMPARISONS</span>
    <h1 style="font-size:clamp(28px,4vw,42px);font-weight:400;color:#fff;margin:16px 0 12px;line-height:1.2;">Smart Ring Comparisons</h1>
    <p style="font-size:17px;color:rgba(255,255,255,0.55);max-width:600px;margin-bottom:8px;">Head-to-head tests based on real data. No brand partnerships, no bias.</p>
    <p style="font-size:12px;color:rgba(255,255,255,0.3);font-family:monospace;margin-bottom:48px;">📅 Updated {buildDate}</p>

    <div style="display:grid;gap:20px;">
      {articles.map(a => (
        <a href={a.href} style="display:block;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;text-decoration:none;transition:border-color .2s;" onmouseover="this.style.borderColor='rgba(0,255,178,0.3)'" onmouseout="this.style.borderColor='var(--border)'">
          <span class="badge badge--orange" style="font-size:10px;padding:3px 8px;">COMPARISON</span>
          <h2 style="font-size:18px;font-weight:400;color:#fff;margin:10px 0 8px;line-height:1.3;">{a.title}</h2>
          <p style="font-size:14px;color:rgba(255,255,255,0.5);margin:0 0 10px;">{a.desc}</p>
          <span style="font-size:11px;color:rgba(255,255,255,0.25);font-family:monospace;">⏱ {a.time}</span>
        </a>
      ))}
    </div>

    <div style="margin-top:48px;padding:24px;background:var(--surface);border:1px solid var(--border);border-radius:12px;">
      <p style="font-size:13px;color:rgba(255,255,255,0.4);margin-bottom:16px;">Looking for reviews or buying guides?</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/reviews" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Reviews →</a>
        <a href="/guides" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Guides →</a>
      </div>
    </div>
  </div>
</section>
</BaseLayout>
