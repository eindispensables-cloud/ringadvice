---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Best Smart Rings 2026 — Independent Reviews" description="60-day tested smart ring reviews. Honest comparisons of Oura Ring, Samsung Galaxy Ring and more." lang="en">
  <section style="padding:clamp(48px,8vw,96px) 0 clamp(32px,5vw,64px);">
    <div class="container">
      <div style="max-width:680px;">
        <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(0,255,178,0.08);border:1px solid rgba(0,255,178,0.2);border-radius:20px;padding:4px 14px;margin-bottom:24px;">
          <span style="width:6px;height:6px;border-radius:50%;background:#00FFB2;"></span>
          <span style="font-size:11px;color:#00FFB2;font-family:monospace;letter-spacing:0.1em;">UPDATED MAY 2026</span>
        </div>
        <h1 style="font-size:clamp(28px,4vw,48px);line-height:1.15;color:#fff;font-weight:400;margin-bottom:20px;">
          The independent guide to<br/>
          <em style="color:#00FFB2;">smart health rings</em><br/>
          that actually work.
        </h1>
        <p style="font-size:17px;color:rgba(255,255,255,0.55);line-height:1.7;margin-bottom:32px;">
          Real 60-day tests. Side-by-side data. No brand deals — just commissions when you buy through our links.
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="/reviews" class="cta-btn cta-btn--lg">See Best Rings →</a>
          <a href="/es" class="cta-btn cta-btn--outline" style="padding:14px 24px;">🇪🇸 Ver en Español</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
