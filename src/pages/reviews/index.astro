---
import BaseLayout from '../../layouts/BaseLayout.astro';
const now = new Date();
const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const buildDate = `${months[now.getMonth()]} ${now.getFullYear()}`;

const articles = [
  {
    href: '/reviews/best-smart-ring-2026',
    badge: 'PILLAR',
    badgeClass: '',
    title: 'Best Smart Rings of 2026: Complete Independent Ranking',
    desc: 'We tested 8 smart rings for 90 days. This is the most complete and honest ranking you\'ll find.',
    time: '12 min read',
  },
  {
    href: '/reviews/oura-ring-review-after-2-months',
    badge: 'REVIEW',
    badgeClass: '',
    title: 'Oura Ring 4: Honest Review After 2 Months of Real Use',
    desc: '60 days wearing the Oura Ring 4 on my finger. Everything works, what disappoints, and whether it\'s worth the price.',
    time: '9 min read',
  },
  {
    href: '/reviews/is-oura-ring-worth-it-2026',
    badge: 'REVIEW',
    badgeClass: '',
    title: 'Is the Oura Ring Worth It in 2026?',
    desc: 'Honest analysis of whether the Oura Ring 4 justifies its price plus subscription in 2026.',
    time: '8 min read',
  },
  {
    href: '/reviews/best-smart-rings-no-subscription',
    badge: 'REVIEW',
    badgeClass: '',
    title: 'Best Smart Rings Without Monthly Subscription (2026)',
    desc: 'The best smart rings with no subscription fee. Tested and ranked by value for money.',
    time: '9 min read',
  },
  {
    href: '/reviews/smart-ring-sleep-tracking-review',
    badge: 'REVIEW',
    badgeClass: '',
    title: 'Smart Ring Sleep Tracking: Are They Actually Accurate?',
    desc: 'We put sleep tracking to the test across 4 rings. The results might surprise you.',
    time: '10 min read',
  },
];
---
<BaseLayout title="Smart Ring Reviews (2026) — Independent & Unsponsored | RingAdvice" description="Independent smart ring reviews based on real testing. No sponsored content, no brand partnerships. Honest opinions on Oura Ring, Samsung Galaxy Ring and more." lang="en" enPath="/reviews" esPath="/es/analisis">
<section style="padding:clamp(40px,6vw,80px) 0;">
  <div class="container">
    <nav style="margin-bottom:24px;font-size:12px;font-family:monospace;color:rgba(255,255,255,0.3);">
      <a href="/" style="color:rgba(255,255,255,0.35);">ringadvice</a> / <span style="color:#00FFB2;">reviews</span>
    </nav>
    <span class="badge">REVIEWS</span>
    <h1 style="font-size:clamp(28px,4vw,42px);font-weight:400;color:#fff;margin:16px 0 12px;line-height:1.2;">Smart Ring Reviews</h1>
    <p style="font-size:17px;color:rgba(255,255,255,0.55);max-width:600px;margin-bottom:8px;">Independent reviews based on real testing. No sponsored content, no brand partnerships.</p>
    <p style="font-size:12px;color:rgba(255,255,255,0.3);font-family:monospace;margin-bottom:48px;">📅 Updated {buildDate}</p>

    <div style="display:grid;gap:20px;">
      {articles.map(a => (
        <a href={a.href} style="display:block;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;text-decoration:none;transition:border-color .2s;" onmouseover="this.style.borderColor='rgba(0,255,178,0.3)'" onmouseout="this.style.borderColor='var(--border)'">
          <span class={`badge ${a.badgeClass}`} style="font-size:10px;padding:3px 8px;">{a.badge}</span>
          <h2 style="font-size:18px;font-weight:400;color:#fff;margin:10px 0 8px;line-height:1.3;">{a.title}</h2>
          <p style="font-size:14px;color:rgba(255,255,255,0.5);margin:0 0 10px;">{a.desc}</p>
          <span style="font-size:11px;color:rgba(255,255,255,0.25);font-family:monospace;">⏱ {a.time}</span>
        </a>
      ))}
    </div>

    <div style="margin-top:48px;padding:24px;background:var(--surface);border:1px solid var(--border);border-radius:12px;">
      <p style="font-size:13px;color:rgba(255,255,255,0.4);margin-bottom:16px;">Looking for comparisons or buying guides?</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/comparisons" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Comparisons →</a>
        <a href="/guides" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Guides →</a>
      </div>
    </div>
  </div>
</section>
</BaseLayout>
