---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const now = new Date();
const monthsES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const buildDate = `${monthsES[now.getMonth()]} ${now.getFullYear()}`;

const articles = [
  {
    href: '/es/comparativas/samsung-galaxy-ring-vs-oura-ring-cual-comprar',
    title: 'Samsung Galaxy Ring vs Oura Ring 4: Cuál Comprar',
    desc: 'Los dos mejores anillos cara a cara. Cuál gana depende de tu teléfono y prioridades.',
    time: '10 min de lectura',
  },
  {
    href: '/es/comparativas/alternativas-al-oura-ring-que-no-requieren-suscripcion',
    title: 'Alternativas al Oura Ring Sin Suscripción Mensual',
    desc: 'Las mejores alternativas al Oura Ring sin cuota mensual. Analizadas y comparadas.',
    time: '8 min de lectura',
  },
];
---
<BaseLayout title="Comparativas de Anillos Inteligentes (2026) | RingAdvice" description="Comparativas independientes de anillos inteligentes basadas en pruebas reales. Samsung Galaxy Ring vs Oura Ring, alternativas sin suscripción y más." lang="es" enPath="/comparisons" esPath="/es/comparativas">
<section style="padding:clamp(40px,6vw,80px) 0;">
  <div class="container">
    <nav style="margin-bottom:24px;font-size:12px;font-family:monospace;color:rgba(255,255,255,0.3);">
      <a href="/es" style="color:rgba(255,255,255,0.35);">ringadvice</a> / <span style="color:#00FFB2;">comparativas</span>
    </nav>
    <span class="badge badge--orange">COMPARATIVAS</span>
    <h1 style="font-size:clamp(28px,4vw,42px);font-weight:400;color:#fff;margin:16px 0 12px;line-height:1.2;">Comparativas de Anillos Inteligentes</h1>
    <p style="font-size:17px;color:rgba(255,255,255,0.55);max-width:600px;margin-bottom:8px;">Comparativas cara a cara basadas en datos reales. Sin patrocinios ni sesgo.</p>
    <p style="font-size:12px;color:rgba(255,255,255,0.3);font-family:monospace;margin-bottom:48px;">📅 Actualizado en {buildDate}</p>

    <div style="display:grid;gap:20px;">
      {articles.map(a => (
        <a href={a.href} style="display:block;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;text-decoration:none;transition:border-color .2s;" onmouseover="this.style.borderColor='rgba(0,255,178,0.3)'" onmouseout="this.style.borderColor='var(--border)'">
          <span class="badge badge--orange" style="font-size:10px;padding:3px 8px;">COMPARATIVA</span>
          <h2 style="font-size:18px;font-weight:400;color:#fff;margin:10px 0 8px;line-height:1.3;">{a.title}</h2>
          <p style="font-size:14px;color:rgba(255,255,255,0.5);margin:0 0 10px;">{a.desc}</p>
          <span style="font-size:11px;color:rgba(255,255,255,0.25);font-family:monospace;">⏱ {a.time}</span>
        </a>
      ))}
    </div>

    <div style="margin-top:48px;padding:24px;background:var(--surface);border:1px solid var(--border);border-radius:12px;">
      <p style="font-size:13px;color:rgba(255,255,255,0.4);margin-bottom:16px;">¿Buscas análisis o guías de compra?</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/es/analisis" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Análisis →</a>
        <a href="/es/guias" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Guías →</a>
      </div>
    </div>
  </div>
</section>
</BaseLayout>
