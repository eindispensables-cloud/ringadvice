---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Mejores Anillos Inteligentes 2026 — Análisis Independiente" description="Análisis reales de 60 días. Comparativas honestas de Oura Ring, Samsung Galaxy Ring y más." lang="es">
  <section style="padding:clamp(48px,8vw,96px) 0 clamp(32px,5vw,64px);">
    <div class="container">
      <div style="max-width:680px;">
        <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(0,255,178,0.08);border:1px solid rgba(0,255,178,0.2);border-radius:20px;padding:4px 14px;margin-bottom:24px;">
          <span style="width:6px;height:6px;border-radius:50%;background:#00FFB2;"></span>
          <span style="font-size:11px;color:#00FFB2;font-family:monospace;letter-spacing:0.1em;">ACTUALIZADO MAYO 2026</span>
        </div>
        <h1 style="font-size:clamp(28px,4vw,48px);line-height:1.15;color:#fff;font-weight:400;margin-bottom:20px;">
          La guía independiente sobre<br/>
          <em style="color:#00FFB2;">anillos inteligentes</em><br/>
          que realmente funcionan.
        </h1>
        <p style="font-size:17px;color:rgba(255,255,255,0.55);line-height:1.7;margin-bottom:32px;">
          60 días de prueba real. Datos comparados. Sin acuerdos con marcas — solo comisiones cuando compras a través de nuestros enlaces.
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="/es/analisis" class="cta-btn cta-btn--lg">Ver análisis →</a>
          <a href="/" class="cta-btn cta-btn--outline" style="padding:14px 24px;">🇺🇸 View in English</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
