---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const now = new Date();
const monthsES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const buildDate = `${monthsES[now.getMonth()]} ${now.getFullYear()}`;

const articles = [
  {
    href: '/es/analisis/mejor-anillo-inteligente-2026',
    badge: 'PILAR',
    badgeClass: '',
    title: 'Mejor Anillo Inteligente 2026: Ranking Completo e Independiente',
    desc: 'Probamos 8 anillos inteligentes durante 90 días. Este es el ranking más completo y honesto que encontrarás.',
    time: '12 min de lectura',
  },
  {
    href: '/es/analisis/oura-ring-opiniones-tras-2-meses-de-uso',
    badge: 'ANÁLISIS',
    badgeClass: '',
    title: 'Oura Ring 4: Opiniones Tras 2 Meses de Uso Real',
    desc: '60 días con el Oura Ring 4 en el dedo. Lo que funciona, lo que decepciona y si merece el precio.',
    time: '9 min de lectura',
  },
  {
    href: '/es/analisis/oura-ring-vale-la-pena-en-2026',
    badge: 'ANÁLISIS',
    badgeClass: '',
    title: '¿Vale la Pena el Oura Ring en 2026?',
    desc: 'Análisis honesto de si el Oura Ring 4 justifica su precio más suscripción en 2026.',
    time: '8 min de lectura',
  },
  {
    href: '/es/analisis/mejores-anillos-inteligentes-sin-suscripcion-mensual',
    badge: 'ANÁLISIS',
    badgeClass: '',
    title: 'Mejores Anillos Inteligentes Sin Suscripción Mensual (2026)',
    desc: 'Los mejores anillos inteligentes sin cuota mensual. Analizados y clasificados por relación calidad-precio.',
    time: '9 min de lectura',
  },
  {
    href: '/es/analisis/anillo-inteligente-para-medir-el-sueno-opiniones',
    badge: 'ANÁLISIS',
    badgeClass: '',
    title: 'Anillo Inteligente para Medir el Sueño: ¿Son Realmente Precisos?',
    desc: 'Pusimos el seguimiento del sueño a prueba en 4 anillos. Los resultados pueden sorprenderte.',
    time: '10 min de lectura',
  },
];
---
<BaseLayout title="Análisis de Anillos Inteligentes (2026) — Independientes y sin Patrocinios | RingAdvice" description="Análisis independientes de anillos inteligentes basados en pruebas reales. Sin contenido patrocinado. Opiniones honestas sobre Oura Ring, Samsung Galaxy Ring y más." lang="es" enPath="/reviews" esPath="/es/analisis">
<section style="padding:clamp(40px,6vw,80px) 0;">
  <div class="container">
    <nav style="margin-bottom:24px;font-size:12px;font-family:monospace;color:rgba(255,255,255,0.3);">
      <a href="/es" style="color:rgba(255,255,255,0.35);">ringadvice</a> / <span style="color:#00FFB2;">análisis</span>
    </nav>
    <span class="badge">ANÁLISIS</span>
    <h1 style="font-size:clamp(28px,4vw,42px);font-weight:400;color:#fff;margin:16px 0 12px;line-height:1.2;">Análisis de Anillos Inteligentes</h1>
    <p style="font-size:17px;color:rgba(255,255,255,0.55);max-width:600px;margin-bottom:8px;">Análisis independientes basados en pruebas reales. Sin contenido patrocinado ni acuerdos con marcas.</p>
    <p style="font-size:12px;color:rgba(255,255,255,0.3);font-family:monospace;margin-bottom:48px;">📅 Actualizado en {buildDate}</p>

    <div style="display:grid;gap:20px;">
      {articles.map(a => (
        <a href={a.href} style="display:block;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;text-decoration:none;transition:border-color .2s;" onmouseover="this.style.borderColor='rgba(0,255,178,0.3)'" onmouseout="this.style.borderColor='var(--border)'">
          <span class={`badge ${a.badgeClass}`} style="font-size:10px;padding:3px 8px;">{a.badge}</span>
          <h2 style="font-size:18px;font-weight:400;color:#fff;margin:10px 0 8px;line-height:1.3;">{a.title}</h2>
          <p style="font-size:14px;color:rgba(255,255,255,0.5);margin:0 0 10px;">{a.desc}</p>
          <span style="font-size:11px;color:rgba(255,255,255,0.25);font-family:monospace;">⏱ {a.time}</span>
        </a>
      ))}
    </div>

    <div style="margin-top:48px;padding:24px;background:var(--surface);border:1px solid var(--border);border-radius:12px;">
      <p style="font-size:13px;color:rgba(255,255,255,0.4);margin-bottom:16px;">¿Buscas comparativas o guías de compra?</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/es/comparativas" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Comparativas →</a>
        <a href="/es/guias" class="cta-btn cta-btn--outline" style="font-size:13px;padding:8px 16px;">Guías →</a>
      </div>
    </div>
  </div>
</section>
</BaseLayout>
