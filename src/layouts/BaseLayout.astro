---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: 'en' | 'es';
  image?: string;
  enPath?: string;
  esPath?: string;
}

const { title, description, lang = 'en', image = '/og-default.jpg', enPath = '/', esPath = '/es' } = Astro.props;
const isES = lang === 'es';
const canonical = Astro.url.href;

const now = new Date();
const monthsEN = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const monthsES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const buildDate = isES
  ? `${monthsES[now.getMonth()]} ${now.getFullYear()}`
  : `${monthsEN[now.getMonth()]} ${now.getFullYear()}`;

const navItems = isES
  ? [
      { href: '/es', label: 'Inicio' },
      { href: '/es/analisis', label: 'Análisis' },
      { href: '/es/comparativas', label: 'Comparativas' },
      { href: '/es/guias', label: 'Guías' },
    ]
  : [
      { href: '/', label: 'Home' },
      { href: '/reviews', label: 'Reviews' },
      { href: '/comparisons', label: 'Comparisons' },
      { href: '/guides', label: 'Guides' },
    ];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang for bilingual SEO -->
    <link rel="alternate" hreflang="en" href={`https://ringadvice.com${enPath}`} />
    <link rel="alternate" hreflang="es" href={`https://ringadvice.com${esPath}`} />
    <link rel="alternate" hreflang="x-default" href={`https://ringadvice.com${enPath}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={isES ? 'es_ES' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Schema.org WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "RingAdvice",
      "url": "https://ringadvice.com",
      "description": "Independent reviews and comparisons of smart health rings",
      "inLanguage": lang
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="glow-bg"></div>

    <header class="site-header">
      <div class="container">
        <div class="site-header__inner">
          <a href={isES ? '/es' : '/'} class="site-logo">
            <div class="site-logo__icon">◎</div>
            ring<span>advice</span>
          </a>
          <nav class="site-nav">
            {navItems.map(item => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>
          <a href={isES ? '/es/analisis' : '/reviews'} class="cta-btn" style="padding:7px 16px;font-size:13px;">
            {isES ? 'Ver análisis →' : 'See reviews →'}
          </a>
        </div>
      </div>
    </header>

    <main style="position:relative;z-index:1;">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="site-footer__inner">
          <p>© {now.getFullYear()} ringadvice.com · {isES ? 'Guía independiente de anillos inteligentes' : 'Independent smart ring guide'}</p>
          <div>
            <a href={isES ? '/es/privacidad' : '/privacy'}>{isES ? 'Privacidad' : 'Privacy'}</a>
            <a href={esPath} style="margin-left:20px">🇪🇸 ES</a>
            <a href={enPath} style="margin-left:8px">🇺🇸 EN</a>
          </div>
        </div>
        <p class="affiliate-note" style="margin-top:16px">
          {isES
            ? 'ringadvice.com utiliza enlaces de afiliado. Podemos ganar una pequeña comisión si realizas una compra a través de nuestros enlaces, sin coste adicional para ti.'
            : 'ringadvice.com uses affiliate links. We may earn a small commission if you make a purchase through our links, at no extra cost to you.'}
        </p>
      </div>
    </footer>
  </body>
</html>
